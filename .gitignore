# Database & session data
# All local SQLite databases are legacy/scratch now that the app and the
# training pipeline both read/write Neon Postgres (see api/db.py and
# scripts/migrate_to_neon.py / scripts/migrate_training_to_neon.py).
data/*.db
data/*.db.bak.*
data/chat_sessions.json

# Runtime & user data (should not be tracked)
data/user_memory.json

# Generated/derived data (regenerate via scripts/import_and_train.py)
data/cleaned/

# Chroma/vector DB (large, generated, machine-specific)
data/contest_chroma/

# ML model artifacts (regenerate via models/train.py)
models/*.pkl
models/*.joblib

# Runtime-generated PDFs served to users (not source content)
frontend/generated/